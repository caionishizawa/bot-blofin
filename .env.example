# ══════════════════════════════════════════════════════
#  NPK Sinais — BloFin Bot + Dashboard
#  Copie este arquivo para .env e preencha os valores
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ─── Telegram ────────────────────────────────────────
# Obtenha em https://t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID do canal/grupo onde os sinais serão enviados
# Use tools/get_chat_id.py para descobrir o ID
TELEGRAM_CHANNEL_ID=-100123456789

# ─── BloFin API (opcional — para dados privados) ─────
# Crie em https://blofin.com/account/api-manage
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_API_PASSPHRASE=

# Link de afiliado BloFin (aparece nas mensagens de sinal)
BLOFIN_REF_LINK=https://blofin.com/register?referral=SEUCOD

# ─── Claude AI (opcional) ────────────────────────────
# Sem esta chave, o bot usa análise fallback (sem IA)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Dashboard ───────────────────────────────────────
# Chave secreta para assinar tokens JWT
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET=mude-para-uma-chave-aleatoria-forte-aqui

# Usuários do dashboard (formato: usuario:senha)
DASHBOARD_USER_1=admin:senha-forte-aqui
DASHBOARD_USER_2=socio:outra-senha-forte

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO
