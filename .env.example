# ============================================================
# BOT BLOFIN — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git
# ============================================================

# ------------------------------------------------------------
# TELEGRAM
# ------------------------------------------------------------
# Token do bot (obter via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# Canal FREE: resultados pós-fato para aquecer audiência
# Ex: -1001234567890 (ID do grupo/canal público)
TELEGRAM_FREE_CHANNEL_ID=

# Canal VIP: sinais completos para assinantes pagantes
# Ex: -1009876543210 (ID do grupo/canal privado)
TELEGRAM_VIP_CHANNEL_ID=

# Seu Telegram ID pessoal (para receber alertas de admin/health)
# Descubra enviando /start para @userinfobot
TELEGRAM_ADMIN_ID=

# Link de referral BloFin do sideradog
TELEGRAM_REF_LINK=https://blofin.com/register?referral=SEU_CODIGO

# ------------------------------------------------------------
# BLOFIN API (opcional — só para endpoints privados)
# Criar em: https://blofin.com/account/api-management
# ------------------------------------------------------------
BLOFIN_API_KEY=
BLOFIN_API_SECRET=
BLOFIN_API_PASSPHRASE=

# ------------------------------------------------------------
# BANCO DE DADOS
# Railway PostgreSQL: preencher após criar o serviço DB
# Ex: postgresql://blofin:senha@containers-us-west-1.railway.app:5432/railway
# Deixar vazio para usar SQLite local (desenvolvimento)
# ------------------------------------------------------------
DATABASE_URL=

# ------------------------------------------------------------
# ANTHROPIC (Claude — análise LLM dos sinais)
# Obter em: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# CONFIGURAÇÕES DO BOT (opcional — sobrescreve config.yaml)
# ------------------------------------------------------------
LOG_LEVEL=INFO
